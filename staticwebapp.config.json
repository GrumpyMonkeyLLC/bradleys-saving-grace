{
  "routes": [
    {
      "route": "/admin.html",
      "allowedRoles": ["admin"]
    },
    {
      "route": "/admin",
      "allowedRoles": ["admin"]
    },
    {
      "route": "/api/lost-dogs*",
      "methods": ["PUT", "DELETE"],
      "allowedRoles": ["admin"]
    },
    {
      "route": "/api/contact*",
      "methods": ["GET", "DELETE"],
      "allowedRoles": ["admin"]
    },
    {
      "route": "/api/subscribe*",
      "methods": ["GET", "DELETE"],
      "allowedRoles": ["admin"]
    },
    {
      "route": "/api/*",
      "methods": ["GET", "POST"],
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/login",
      "rewrite": "/.auth/login/github"
    },
    {
      "route": "/logout",
      "rewrite": "/.auth/logout"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/images/*", "/css/*", "/js/*", "/*.{png,jpg,gif,ico,svg,webp}"]
  },
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/github?post_login_redirect_uri=/admin.html",
      "statusCode": 302
    },
    "403": {
      "rewrite": "/unauthorized.html",
      "statusCode": 403
    },
    "404": {
      "rewrite": "/404.html"
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "Content-Security-Policy": "default-src 'self' 'unsafe-inline' 'unsafe-eval' fonts.googleapis.com fonts.gstatic.com; img-src 'self' data: blob: *.blob.core.windows.net"
  },
  "mimeTypes": {
    ".json": "text/json"
  }
}

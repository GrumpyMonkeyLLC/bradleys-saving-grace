{
  "routes": [
    {
      "route": "/admin",
      "allowedRoles": ["admin"]
    },
    {
      "route": "/admin/*",
      "allowedRoles": ["admin"]
    },
    {
      "route": "/api/*",
      "methods": ["GET","POST","PUT","DELETE"],
      "allowedRoles": ["anonymous","authenticated"]
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/images/*", "/css/*", "/js/*", "/*.{png,jpg,gif,ico,svg,webp}"]
  },
  "responseOverrides": {
    "401": {
      "redirect": "/login",
      "statusCode": 302
    },
    "404": {
      "rewrite": "/404.html"
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "Content-Security-Policy": "default-src 'self' 'unsafe-inline' 'unsafe-eval' fonts.googleapis.com fonts.gstatic.com; img-src 'self' data: blob: *.blob.core.windows.net"
  },
  "mimeTypes": {
    ".json": "text/json"
  }
}
